generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model certificates {
  id              String    @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  user_id         String?   @db.VarChar(36)
  name            String    @db.VarChar(255)
  organization    String?   @db.VarChar(150)
  issue_date      DateTime? @db.Date
  expiration_date DateTime? @db.Date
  credential_id   String?   @db.VarChar(100)
  credential_url  String?   @db.VarChar(255)
  image_url       String?   @db.VarChar(255)
  users           users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "certificates_ibfk_1")

  @@index([user_id], map: "user_id")
}

model experiences {
  id           String    @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  user_id      String?   @db.VarChar(36)
  company_name String    @db.VarChar(150)
  position     String    @db.VarChar(100)
  start_date   DateTime  @db.Date
  end_date     DateTime? @db.Date
  description  String?   @db.Text
  users        users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "experiences_ibfk_1")

  @@index([user_id], map: "user_id")
}

model project_images {
  id            String    @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  project_id    String?   @db.VarChar(36)
  image_url     String    @db.VarChar(255)
  display_order Int?      @default(0)
  projects      projects? @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "project_images_ibfk_1")

  @@index([project_id], map: "project_id")
}

model project_tech_stack {
  project_id String     @db.VarChar(36)
  tech_id    String     @db.VarChar(36)
  projects   projects   @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "project_tech_stack_ibfk_1")
  tech_stack tech_stack @relation(fields: [tech_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "project_tech_stack_ibfk_2")

  @@id([project_id, tech_id])
  @@index([tech_id], map: "tech_id")
}

model projects {
  id                 String               @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  user_id            String?              @db.VarChar(36)
  title              String               @db.VarChar(150)
  description        String?              @db.Text
  thumbnail          String?              @db.VarChar(255)
  demo_url           String?              @db.VarChar(255)
  github_url         String?              @db.VarChar(255)
  order_index        Int?                 @default(0)
  created_at         DateTime?            @default(now()) @db.Timestamp(0)
  is_active          Boolean?             @default(true)
  project_images     project_images[]
  project_tech_stack project_tech_stack[]
  users              users?               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "projects_ibfk_1")

  @@index([user_id], map: "user_id")
}

model skills {
  id       String  @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  user_id  String? @db.VarChar(36)
  name     String  @db.VarChar(50)
  level    Int?    @default(100)
  category String? @db.VarChar(30)
  users    users?  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "skills_ibfk_1")

  @@index([user_id], map: "user_id")
}

model tech_stack {
  id                 String               @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  name               String               @unique(map: "name") @db.VarChar(50)
  icon_url           String?              @db.VarChar(255)
  project_tech_stack project_tech_stack[]
}

model users {
  id              String           @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  username        String           @db.VarChar(20)
  email           String           @unique @db.VarChar(100)
  pass            String           @db.VarChar(100)
  major           users_major
  created_at      DateTime?        @default(now()) @db.Timestamp(0)
  role            users_role       @default(user)
  refresh_token   String?          @db.VarChar(1000)
  resetToken      String?          @db.VarChar(30)
  images_url      String?          @db.VarChar(500)
  certificates    certificates[]
  experiences     experiences[]
  projects        projects[]
  skills          skills[]
  user_portfolios user_portfolios?
  
  user_themes     user_themes[]
  transactions    transactions[]
  journalist_articles   journalist_articles[]
  business_achievements business_achievements[]
  economic_research     economic_research[]
}

model theme_templates {
  id             String   @id @default(uuid())
  slug           String   @unique
  name           String
  description    String?  @db.Text
  preview_images Json?
  price          Decimal  @default(0.00) @db.Decimal(10, 2)
  default_config Json
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  stock_limit    Int?
  sales_count    Int      @default(0)
  is_active      Boolean  @default(true)

  portfolios     user_portfolios[]
  user_themes    user_themes[]
  transactions   transactions[]
}

model user_themes {
  id           String          @id @default(uuid())
  user_id      String          @db.VarChar(36)
  theme_id     String
  purchased_at DateTime        @default(now())
  expires_at   DateTime?       
  
  user         users           @relation(fields: [user_id], references: [id])
  theme        theme_templates @relation(fields: [theme_id], references: [id])

  @@unique([user_id, theme_id])
  @@index([user_id])
  @@index([theme_id])
}

model user_portfolios {
  id            String          @id @default(uuid())
  user_id       String          @unique
  theme_id      String
  custom_config Json?
  title         String?
  bio           String?         @db.Text
  theme         theme_templates @relation(fields: [theme_id], references: [id])
  user          users           @relation(fields: [user_id], references: [id])
}

model transactions {
  id             String          @id @default(uuid())
  user_id        String          @db.VarChar(36)
  theme_id       String
  amount         Decimal         @db.Decimal(10, 2)
  status         TransactionStatus @default(PENDING)
  payment_method String?         
  transaction_id String?         @unique 
  created_at     DateTime        @default(now())

  user           users           @relation(fields: [user_id], references: [id])
  theme          theme_templates @relation(fields: [theme_id], references: [id])

  @@index([user_id])
  @@index([theme_id])
}

model journalist_articles {
  id             String   @id @default(uuid())
  user_id        String   @db.VarChar(36)
  title          String   // Tiêu đề bài báo
  summary        String?  @db.Text // Tóm tắt nội dung (Sapo)
  content_url    String   // Link bài báo online
  publisher_name String   // Tên tòa soạn (VD: VnExpress, Tuổi Trẻ...)
  category       String?  // Chuyên mục (VD: Chính trị, Văn hóa, Xã hội)
  published_at   DateTime? @db.Date
  thumbnail_url  String?
  
  user           users    @relation(fields: [user_id], references: [id])
  tags           Json?    // Lưu các từ khóa/kỹ năng (VD: ["Phỏng vấn", "Điều tra"])
}
model business_achievements {
  id            String   @id @default(uuid())
  user_id       String   @db.VarChar(36)
  title         String   // Tên thành tựu (VD: Tăng trưởng doanh thu, Quản lý ngân sách)
  description   String?  @db.Text
  
  // Trường đặc thù cho kinh tế: Con số thực tế
  metric_value  String?  // Giá trị (VD: "20", "1.5")
  metric_unit   String?  // Đơn vị (VD: "%", "Tỷ VNĐ", "Triệu USD")
  
  achieved_at   DateTime? @db.Date
  organization  String?  // Tại đơn vị nào?

  user          users    @relation(fields: [user_id], references: [id])
  tags          Json?    // Lưu các công cụ/kỹ năng (VD: ["Excel", "SAP"])
}

model economic_research {
  id            String   @id @default(uuid())
  user_id       String   @db.VarChar(36)
  title         String   // Tên báo cáo/nghiên cứu thị trường
  organization  String?  // Đơn vị chủ quản/khách hàng
  summary       String?  @db.Text
  file_url      String?  // Link file PDF báo cáo
  published_at  DateTime? @db.Date

  user          users    @relation(fields: [user_id], references: [id])
  tags          Json?    // Lưu các từ khóa (VD: ["Market Research", "Data Analysis"])
}


enum users_major {
  it
  journalist
  designer
  other
}

enum users_role {
  admin
  user
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
